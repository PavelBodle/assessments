# ── HelpMate configuration ──────────────────────────────────────────────
# Copy to `.env` and fill in. Switching models = edit THIS file only.

# LLM provider + model (the ONLY place a model id is set)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1

# Provider API key (Gemini free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-key-here

# Embeddings — HuggingFace sentence-transformers model id (runs locally)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Agent behaviour
MAX_TOOL_CALLS=12
