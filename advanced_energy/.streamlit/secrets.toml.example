# Copy to .streamlit/secrets.toml (gitignored) for local Streamlit runs, or
# paste these into the Streamlit Community Cloud "Secrets" dashboard on deploy.
LLM_PROVIDER = "gemini"
LLM_MODEL = "gemini-2.5-flash"
LLM_TEMPERATURE = "0.1"
GEMINI_API_KEY = "your-key-here"
EMBEDDING_MODEL = "BAAI/bge-small-en-v1.5"
MAX_TOOL_CALLS = "12"
